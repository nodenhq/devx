# Target Odoo version (12.0, 13.0, 14.0, 15.0, 16.0, 17.0, 18.0, 19.0)
ODOO_VERSION=19.0

# Postgres version — v12–v14 Odoo prefer 13; v15+ works with 16
POSTGRES_VERSION=16

# Host ports (change if they collide with another container)
ODOO_PORT=8069
ODOO_LONGPOLLING_PORT=8072

# Database credentials
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo
POSTGRES_DB=postgres

# Odoo → DB connection
HOST=db
USER=odoo
PASSWORD=odoo
